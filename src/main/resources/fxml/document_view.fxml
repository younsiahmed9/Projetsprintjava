<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1.0"
            fx:controller="Controllers.DocumentViewController"
            stylesheets="@../css/styles.css"
            styleClass="main-container">

    <top>
        <VBox spacing="8" styleClass="page-header">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Gestion des Documents" styleClass="header-title-blue"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnGoToDashboard" text="📊" styleClass="btn-add-circle"
                        style="-fx-font-size: 18; -fx-padding: 8; -fx-background-color: #2563eb;"/>
                <Button fx:id="btnAddDocument" text="+" styleClass="btn-add-circle"/>
            </HBox>
            <Label text="Organisez et gerez vos documents en toute facilite"
                   styleClass="subtitle-text"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="25" VBox.vgrow="ALWAYS">
            <!-- Carte Dossiers (≈30%) -->
            <VBox spacing="12" styleClass="card sidebar-card"
                  prefWidth="330" minWidth="300" maxWidth="380"
                  maxHeight="Infinity">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📁 Dossiers" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnManageFolders" styleClass="btn-manage-folders-premium"/>
                </HBox>

                <Separator />

                <Button fx:id="btnAllDocuments" text="📋 Tous les documents" styleClass="nav-item nav-item-active"/>
                <Button fx:id="btnTrash" text="🗑️ Corbeille" styleClass="nav-item"/>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="transparent-scroll">
                    <VBox fx:id="containerFolders" spacing="5" styleClass="list-container"/>
                </ScrollPane>

                <Button fx:id="btnAddFolder" text="+ Ajouter un dossier" maxWidth="Infinity" styleClass="btn-yellow-premium"/>
            </VBox>

            <!-- Carte Documents (≈70%) -->
            <VBox spacing="12" styleClass="card"
                  HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="tfSearch"
                               promptText="🔍 Rechercher un document..."
                               styleClass="search-field-premium"
                               HBox.hgrow="ALWAYS"/>

                    <ComboBox fx:id="cbCategory"
                              promptText="📁 Categorie"
                               styleClass="filter-combo-premium"
                               prefWidth="180"/>

                    <Button fx:id="btnManageCategories" styleClass="btn-manage-categories-premium"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="meta-bar">
                    <Label fx:id="lblDocCount" text="0 documents" styleClass="meta-text"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblFilterInfo" text="" styleClass="filter-chip"/>
                    <Button fx:id="btnRefresh" styleClass="btn-refresh-premium"/>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="transparent-scroll">
                    <VBox fx:id="containerDocuments" spacing="10" styleClass="list-container"/>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox styleClass="status-bar">
            <Label fx:id="lblStatus" text="Pret" styleClass="status-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="v2.0" styleClass="version-text"/>
        </HBox>
    </bottom>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
</BorderPane>
