<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="500" prefWidth="600" spacing="15" styleClass="root" stylesheets="@/css/app.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.AiAssistantController" style="-fx-padding: 20;">
    <Label styleClass="title" text="🤖 Assistant IA - Formulation Fintech" />
    
    <Label styleClass="field-label" text="Votre message ou idée (informel) :" />
    <TextArea fx:id="userInputArea" promptText="Ex: je veux demander un pret de 5000 pour mon projet..." prefHeight="120" wrapText="true" styleClass="enhanced-focus" />
    
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <ProgressIndicator fx:id="loadingIndicator" visible="false" prefHeight="24" prefWidth="24" />
        <Button fx:id="improveBtn" onAction="#onImproveMessage" styleClass="btn-primary" text="✨ Améliorer mon message" />
    </HBox>
    
    <Separator />
    
    <Label styleClass="field-label" text="Suggestion de l'IA (Professionnel) :" />
    <TextArea fx:id="aiSuggestionArea" editable="false" prefHeight="180" wrapText="true" styleClass="card" style="-fx-font-style: italic; -fx-background-color: #f9fafb;" />
    
    <HBox alignment="CENTER_RIGHT">
        <Button onAction="#onCopy" styleClass="btn-link" text="📋 Copier le résultat" />
    </HBox>
</VBox>
