<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.PortefeuilleController"
            prefHeight="650.0" prefWidth="1000.0">

    <left>
        <VBox spacing="10" prefWidth="220" style="-fx-background-color: #1f2a44;" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16" right="12" bottom="16" left="12"/>
            </padding>

            <Label text="FinTrack" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Separator/>

            <Button text="Portefeuilles" maxWidth="Infinity"/>
            <Button text="Cartes virtuelles" onAction="#handleVoirCartes" maxWidth="Infinity"/>
            <Separator/>
            <Button text="Déconnexion" onAction="#handleDeconnexion" maxWidth="Infinity"/>

            <Pane VBox.vgrow="ALWAYS"/>

            <HBox spacing="6">
                <Label text="Connecté:" style="-fx-text-fill: #cbd5e1;"/>
                <Label fx:id="userLabel" text="-" style="-fx-text-fill: #cbd5e1;"/>
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="12" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Gestion des portefeuilles" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Rafraîchir" onAction="#handleRefresh"/>
            </HBox>

            <TableView fx:id="portefeuilleTable" prefHeight="360">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="70"/>
                    <TableColumn fx:id="nomColumn" text="Nom" prefWidth="260"/>
                    <TableColumn fx:id="soldeColumn" text="Solde" prefWidth="160"/>
                    <TableColumn fx:id="deviseColumn" text="Devise" prefWidth="120"/>
                </columns>
            </TableView>

            <TitledPane text="Formulaire" expanded="true">
                <content>
                    <GridPane hgap="10" vgap="10">
                        <padding>
                            <Insets top="12" right="12" bottom="12" left="12"/>
                        </padding>

                        <Label text="Nom" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="nomField" promptText="Nom du portefeuille" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Solde" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="soldeField" promptText="0.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Devise" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <ComboBox fx:id="deviseCombo" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3">
                            <Button text="Ajouter" onAction="#handleAjouter"/>
                            <Button text="Modifier" onAction="#handleModifier"/>
                            <Button text="Supprimer" onAction="#handleSupprimer"/>
                        </HBox>

                        <Label fx:id="messageLabel" style="-fx-text-fill: #c0392b;" GridPane.columnIndex="1" GridPane.rowIndex="4" wrapText="true"/>
                    </GridPane>
                </content>
            </TitledPane>
        </VBox>
    </center>

</BorderPane>
