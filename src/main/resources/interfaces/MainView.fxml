<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane style="-fx-background-color: #d2e7fe;" styleClass="main-container" stylesheets="@/styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MainController">

    <!-- LEFT: Navbar -->
    <left>
        <VBox prefWidth="260" spacing="10" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(24,45,136,0.1), 10, 0, 0, 0);" styleClass="sidebar">
            <padding>
                <Insets bottom="30" left="20" right="20" top="30" />
            </padding>

            <!-- Logo Section -->
            <VBox alignment="CENTER" spacing="15">
                <ImageView fitHeight="69.0" fitWidth="193.0">
                    <image>
                        <Image url="@/images/logo.png" />
                    </image>
                </ImageView>
            </VBox>

            <!-- Navigation Items -->
            <VBox spacing="5" styleClass="sidebar-menu">
                <HBox fx:id="navServices" alignment="CENTER_LEFT" onMouseClicked="#handleServices" spacing="12" styleClass="sidebar-item">
                    <Circle fx:id="circleServices" styleClass="sidebar-circle-inactive" radius="6" />
                    <Text fx:id="textServices" styleClass="sidebar-text" text="Services et Abonnements" />
                </HBox>

                <HBox fx:id="navFactures" alignment="CENTER_LEFT" onMouseClicked="#handleFactures" spacing="12" styleClass="sidebar-item">
                    <Circle fx:id="circleFactures" styleClass="sidebar-circle-inactive" radius="6" />
                    <Text fx:id="textFactures" styleClass="sidebar-text" text="Factures" />
                </HBox>

                <HBox fx:id="navComptes" alignment="CENTER_LEFT" onMouseClicked="#handleComptes" spacing="12" styleClass="sidebar-item">
                    <Circle fx:id="circleComptes" styleClass="sidebar-circle-inactive" radius="6" />
                    <Text fx:id="textComptes" styleClass="sidebar-text" text="Comptes" />
                </HBox>

                <HBox fx:id="navDepenses" alignment="CENTER_LEFT" onMouseClicked="#handleDepenses" spacing="12" styleClass="sidebar-item">
                    <Circle fx:id="circleDepenses" styleClass="sidebar-circle-inactive" radius="6" />
                    <Text fx:id="textDepenses" styleClass="sidebar-text" text="Dépenses" />
                </HBox>

                <HBox fx:id="navBudget" alignment="CENTER_LEFT" onMouseClicked="#handleBudget" spacing="12" styleClass="sidebar-item">
                    <Circle fx:id="circleBudget" styleClass="sidebar-circle-inactive" radius="6" />
                    <Text fx:id="textBudget" styleClass="sidebar-text" text="Budget" />
                </HBox>

                <HBox fx:id="navDocuments" alignment="CENTER_LEFT" onMouseClicked="#handleDocuments" spacing="12" styleClass="sidebar-item">
                    <Circle fx:id="circleDocuments" styleClass="sidebar-circle-inactive" radius="6" />
                    <Text fx:id="textDocuments" styleClass="sidebar-text" text="Documents" />
                </HBox>

                <HBox fx:id="navDashboard" alignment="CENTER_LEFT" onMouseClicked="#handleDashboard" spacing="12" styleClass="sidebar-item">
                    <Circle fx:id="circleDashboard" styleClass="sidebar-circle-inactive" radius="6" />
                    <Text fx:id="textDashboard" styleClass="sidebar-text" text="Dashboard" />
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <!-- User Profile -->
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="user-profile">
                <Circle styleClass="user-avatar" radius="20" />
                <VBox>
                    <Text styleClass="user-name" text="Syrine Chakroun" />
                    <Text styleClass="user-email" text="syrine@email.com" />
                </VBox>
                <MenuButton styleClass="menu-button" text="...">
                    <items>
                        <MenuItem onAction="#handleProfil" text="Mon Profil" />
                        <MenuItem onAction="#handleParametres" text="Paramètres" />
                        <SeparatorMenuItem />
                        <MenuItem onAction="#handleDeconnexion" text="Déconnexion" />
                        <MenuItem onAction="#handleQuitter" text="Quitter" />
                    </items>
                </MenuButton>
            </HBox>
        </VBox>
    </left>

    <!-- CENTER: Main Content -->
    <center>
        <BorderPane fx:id="mainPane" />
    </center>
</BorderPane>