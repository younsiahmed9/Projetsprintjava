<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToWidth="true" styleClass="main-container" stylesheets="@/styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ServiceController">
    <content>
        <VBox>
            <!-- Top Bar avec tous les boutons -->
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-bar">
                <padding>
                    <Insets bottom="15" left="30" right="30" top="15" />
                </padding>

                <!-- Recherche -->
                <HBox styleClass="search-box" HBox.hgrow="ALWAYS">
                    <TextField fx:id="searchServiceField" promptText="Rechercher un service..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Filtre Statut -->
                <ComboBox fx:id="filterStatutService" prefWidth="120" promptText="Statut" styleClass="filter-combo" />

                <!-- BOUTONS : Ajouter Service, Ajouter Produit, Factures -->
                <Button fx:id="addServiceButton" text="+ Ajouter Service" onAction="#ajouterService" styleClass="btn-add" />
                <Button fx:id="addProductButton" text="+ Ajouter Produit" onAction="#ajouterProduit" styleClass="btn-add" />
                <Button fx:id="factureButton" text="📄 Factures" onAction="#handleFactures" styleClass="btn-primary" />            </HBox>

            <!-- Stats Cards -->
            <HBox spacing="20" styleClass="stats-container">
                <VBox styleClass="stats-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Circle fill="#f78f34" radius="8" />
                        <Text styleClass="stats-title" text="Services" />
                    </HBox>
                    <Text fx:id="totalServices" styleClass="stats-number" text="0" />
                </VBox>

                <VBox styleClass="stats-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Circle fill="#fecf47" radius="8" />
                        <Text styleClass="stats-title" text="Produits" />
                    </HBox>
                    <Text fx:id="totalProduits" styleClass="stats-number" text="0" />
                </VBox>
            </HBox>

            <!-- Content Area with Tabs -->
            <TabPane VBox.vgrow="ALWAYS">
                <Tab closable="false" text="Services">
                    <ScrollPane fitToWidth="true">
                        <FlowPane fx:id="servicesFlow" hgap="20" vgap="20" styleClass="flow-pane" />
                    </ScrollPane>
                </Tab>
                <Tab closable="false" text="Produits">
                    <ScrollPane fitToWidth="true">
                        <FlowPane fx:id="produitsFlow" hgap="20" vgap="20" styleClass="flow-pane" />
                    </ScrollPane>
                </Tab>
            </TabPane>
        </VBox>
    </content>
</ScrollPane>