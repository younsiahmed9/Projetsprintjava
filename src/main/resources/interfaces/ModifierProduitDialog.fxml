<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<DialogPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ModifierProduitController">
    <headerText>
        Modifier un produit
    </headerText>
    <content>
        <GridPane hgap="10" vgap="10">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <!-- Ligne 1: Nom -->
            <Label text="Nom du produit:" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <TextField fx:id="nomField" promptText="Ex: Carte Cadeau" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS" />
            <Label fx:id="nomError" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="0" />

            <!-- Ligne 2: Type -->
            <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <ComboBox fx:id="typeCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label fx:id="typeError" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="1" />

            <!-- Ligne 3: Montant -->
            <Label text="Montant (DT):" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <TextField fx:id="montantField" promptText="Ex: 50.00" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label fx:id="montantError" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="2" />

            <!-- Ligne 4: Code unique -->
            <Label text="Code unique:" GridPane.columnIndex="0" GridPane.rowIndex="3">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <TextField fx:id="codeField" promptText="Ex: CARTE-2024-001" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Label fx:id="codeError" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="3" />

            <!-- Ligne 5: Statut -->
            <Label text="Statut:" GridPane.columnIndex="0" GridPane.rowIndex="4">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <ComboBox fx:id="statutCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            <Label fx:id="statutError" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="4" />

            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" minWidth="100" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                <ColumnConstraints minWidth="20" />
            </columnConstraints>
        </GridPane>
    </content>
    <ButtonType fx:constant="OK" />
    <ButtonType fx:constant="CANCEL" />
</DialogPane>