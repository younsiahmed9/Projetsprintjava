<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="card" spacing="12" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-radius: 15;"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="interfaces.ProduitCardController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <!-- En-tête -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Circle fx:id="iconCircle" radius="25" fill="#8dbc71" />
        <VBox spacing="5">
            <Text fx:id="nomProduit" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-fill: #182d88;" />
            <Text fx:id="typeProduit" style="-fx-font-size: 12px; -fx-fill: #182d88; -fx-opacity: 0.7;" />
        </VBox>
    </HBox>

    <!-- Détails -->
    <VBox spacing="8" style="-fx-padding: 10 0;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Text text="💰" />
            <Text fx:id="montant" style="-fx-font-size: 14px; -fx-fill: #182d88;" />
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Text text="🔑" />
            <Text fx:id="codeUnique" style="-fx-font-size: 13px; -fx-fill: #182d88; -fx-opacity: 0.7;" />
        </HBox>
    </VBox>

    <!-- Statut -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Circle fx:id="statutDot" radius="6" />
        <Text fx:id="statut" style="-fx-font-size: 12px; -fx-font-weight: bold;" />
    </HBox>

    <!-- Boutons -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Modifier" style="-fx-background-color: #182d88; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 12px; -fx-cursor: hand;"
                onAction="#handleModifier">
            <padding><Insets bottom="6" left="15" right="15" top="6" /></padding>
        </Button>
        <Button text="Supprimer" style="-fx-background-color: #f78f34; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 12px; -fx-cursor: hand;"
                onAction="#handleSupprimer">
            <padding><Insets bottom="6" left="15" right="15" top="6" /></padding>
        </Button>
    </HBox>
</VBox>