<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.LoginController"
            style="-fx-background-color: linear-gradient(to bottom right, #1a3a52, #2c5aa0);">

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 40;">

            <VBox alignment="CENTER" spacing="5">
                <Label text="FinTrack" style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Gestion de Portefeuilles et Cartes Virtuelles"
                       style="-fx-font-size: 14; -fx-text-fill: #b0c4de;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 5);">

                <Label text="Connexion" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a3a52;"/>

                <VBox spacing="5" alignment="CENTER_LEFT" style="-fx-min-width: 300;">
                    <Label text="Email" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <TextField fx:id="emailField" promptText="votre@email.com"
                               style="-fx-padding: 12; -fx-font-size: 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd;"/>
                </VBox>

                <VBox spacing="5" alignment="CENTER_LEFT" style="-fx-min-width: 300;">
                    <Label text="Mot de passe" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <PasswordField fx:id="passwordField" promptText="********"
                                   style="-fx-padding: 12; -fx-font-size: 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd;"/>
                </VBox>

                <Button text="Se connecter" onAction="#handleLogin"
                        style="-fx-background-color: #2c5aa0; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 12 60; -fx-background-radius: 8; -fx-cursor: hand;"
                        maxWidth="Infinity"/>

                <Label fx:id="messageLabel" wrapText="true" alignment="CENTER"
                       style="-fx-font-size: 12; -fx-padding: 10;"/>

            </VBox>

            <Label text="2026 FinTrack - Tous droits reserves"
                   style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;"/>

        </VBox>
    </center>

</BorderPane>

