<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1.0"
      fx:controller="Controllers.CategorieController"
      spacing="20"
      style="-fx-padding: 20;">

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Catégories" styleClass="header-title-blue"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="⟳" onAction="#onRefresh" styleClass="btn-secondary" style="-fx-font-size: 16;"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="15" HBox.hgrow="ALWAYS" styleClass="card">
            <Label text="Liste des catégories" styleClass="section-title"/>
            <ListView fx:id="listCategories" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="15" prefWidth="400" styleClass="card">
            <Label text="Ajouter/Modifier Catégorie" styleClass="section-title"/>

            <Label text="Nom de la catégorie" style="-fx-font-weight: bold; -fx-text-fill: #182d88;"/>
            <TextField fx:id="tfNom" styleClass="modern-input" promptText="Ex: Important"/>

            <Label text="Description" style="-fx-font-weight: bold; -fx-text-fill: #182d88;"/>
            <TextArea fx:id="taDesc" styleClass="modern-input" promptText="Description..." prefRowCount="4"/>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="10">
                <Button text="✓ Ajouter" onAction="#onAdd" styleClass="btn-primary" HBox.hgrow="ALWAYS"/>
                <Button text="✎ Modifier" onAction="#onUpdate" styleClass="btn-action-light-blue" HBox.hgrow="ALWAYS"/>
                <Button text="✕ Supprimer" onAction="#onDelete" styleClass="btn-danger" HBox.hgrow="ALWAYS"/>
            </HBox>

            <Button text="Effacer" onAction="#onClear" styleClass="btn-secondary" maxWidth="Infinity"/>
        </VBox>
    </HBox>
</VBox>

