<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" styleClass="form-container" stylesheets="@/styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.EnvoiFactureController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Envoi de facture" styleClass="header-title-blue" />

    <GridPane hgap="10" vgap="10">
        <Label text="Email client:" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="emailClientField" promptText="client@email.com" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Nom client:" styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="nomClientField" promptText="Jean Dupont" GridPane.rowIndex="1" GridPane.columnIndex="1" />
    </GridPane>

    <TitledPane text="Options" expanded="true">
        <VBox spacing="10">
            <RadioButton fx:id="radioPDF" text="Générer PDF uniquement" selected="true" />
            <RadioButton fx:id="radioEmail" text="Générer PDF et envoyer par email" />
        </VBox>
    </TitledPane>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleAnnuler" styleClass="btn-cancel-flat" />
        <Button text="Valider" onAction="#handleOk" styleClass="btn-save" />
    </HBox>
</VBox>