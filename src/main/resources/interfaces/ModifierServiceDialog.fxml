<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<DialogPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ModifierServiceController">
    <headerText>
        Modifier un service
    </headerText>
    <content>
        <GridPane hgap="10" vgap="10">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <!-- Ligne 1: Nom -->
            <Label text="Nom du service:" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <TextField fx:id="nomField" promptText="Ex: Abonnement Premium" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS" />
            <Label fx:id="nomError" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="0" />

            <!-- Ligne 2: Type -->
            <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <ComboBox fx:id="typeCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label fx:id="typeError" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="1" />

            <!-- Ligne 3: Tarif -->
            <Label text="Tarif (DT):" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <TextField fx:id="tarifField" promptText="Ex: 99.99" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label fx:id="tarifError" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="2" />

            <!-- Ligne 4: Fréquence -->
            <Label text="Fréquence:" GridPane.columnIndex="0" GridPane.rowIndex="3">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <ComboBox fx:id="frequenceCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Label fx:id="frequenceError" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="3" />

            <!-- Ligne 5: Date début -->
            <Label text="Date début:" GridPane.columnIndex="0" GridPane.rowIndex="4">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <DatePicker fx:id="dateDebutPicker" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            <Label fx:id="dateError" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="4" />

            <!-- Ligne 6: Date fin -->
            <Label text="Date fin:" GridPane.columnIndex="0" GridPane.rowIndex="5">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <DatePicker fx:id="dateFinPicker" GridPane.columnIndex="1" GridPane.rowIndex="5" />

            <!-- Ligne 7: Statut -->
            <Label text="Statut:" GridPane.columnIndex="0" GridPane.rowIndex="6">
                <font>
                    <Font name="System Bold" size="12" />
                </font>
            </Label>
            <ComboBox fx:id="statutCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="6" />
            <Label fx:id="statutError" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="6" />

            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" minWidth="100" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                <ColumnConstraints minWidth="20" />
            </columnConstraints>
        </GridPane>
    </content>
    <ButtonType fx:constant="OK" />
    <ButtonType fx:constant="CANCEL" />
</DialogPane>