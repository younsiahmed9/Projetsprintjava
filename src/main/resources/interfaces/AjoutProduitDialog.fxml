<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AjoutProduitController" spacing="15"
      styleClass="form-container" stylesheets="/styles/style.css">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <GridPane hgap="10" vgap="15">
        <Label text="Nom du produit:" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nomField" promptText="Ex: Carte cadeau Amazon" styleClass="form-field" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label fx:id="nomError" styleClass="error-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>

        <Label text="Type:" styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="typeCombo" promptText="Choisir un type" styleClass="form-field" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="200"/>
        <Label fx:id="typeError" styleClass="error-label" GridPane.rowIndex="1" GridPane.columnIndex="2"/>

        <Label text="Montant (DT):" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="montantField" promptText="Ex: 50.00" styleClass="form-field" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label fx:id="montantError" styleClass="error-label" GridPane.rowIndex="2" GridPane.columnIndex="2"/>

        <Label text="Code Unique:" styleClass="field-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="codeUniqueField" promptText="Ex: AMZ-FR-123456" styleClass="form-field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Label fx:id="codeError" styleClass="error-label" GridPane.rowIndex="3" GridPane.columnIndex="2"/>

        <Label text="Date de création:" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dateCreationPicker" styleClass="form-field" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
        <Label fx:id="dateError" styleClass="error-label" GridPane.rowIndex="4" GridPane.columnIndex="2"/>

        <Label text="Statut:" styleClass="field-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <ComboBox fx:id="statutCombo" styleClass="form-field" GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="200"/>
        <Label fx:id="statutError" styleClass="error-label" GridPane.rowIndex="5" GridPane.columnIndex="2"/>
    </GridPane>
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button fx:id="okButton" onAction="#handleOk" text="Enregistrer" styleClass="btn-save"/>
        <Button onAction="#handleCancel" text="Annuler" styleClass="btn-cancel-flat"/>
    </HBox>
</VBox>