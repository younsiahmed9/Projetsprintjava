<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane styleClass="root" stylesheets="@/css/app.css,@/css/theme-orange.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.AdminDashboardController">
    <VBox spacing="16" style="-fx-padding: 20;">
        <!-- New Header with search or just title and logout -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <ImageView fx:id="headerAvatarView" fitHeight="40" fitWidth="40" onMouseClicked="#onHeaderAvatarClick" preserveRatio="true" styleClass="header-avatar" />
            <Label styleClass="title" style="-fx-font-size: 24px;" text="Administration - Dashboard" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button onAction="#onToggleTheme" styleClass="btn-secondary" text="🎨 Thème" />
            <Button onAction="#onLogout" styleClass="btn-primary" text="🚪 Déconnexion" />
        </HBox>

        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" hbarPolicy="NEVER" pannable="true" styleClass="modern-scroll-pane" VBox.vgrow="ALWAYS">
            <content>
                <VBox fx:id="adminDashboardBox" fillWidth="true" spacing="20">
                    <!-- Stats Cards -->
                    <HBox spacing="20">
                        <VBox alignment="CENTER" prefHeight="120" spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="Administrateurs" />
                            <Label fx:id="adminCountLabel" style="-fx-font-size: 32px;" styleClass="title" text="0" />
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="120" spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="Clients" />
                            <Label fx:id="clientCountLabel" style="-fx-font-size: 32px;" styleClass="title" text="0" />
                        </VBox>
                    </HBox>

                    <!-- Users Table Card -->
                    <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Label styleClass="title" text="🧑‍💼 Gestion des Utilisateurs" />
                            <Pane HBox.hgrow="ALWAYS" />
                            <Button onAction="#onAdminAddUser" styleClass="btn-add-user" text="+" />
                            <Button onAction="#onAdminRefresh" styleClass="btn-link" text="Rafraîchir" />
                        </HBox>
                        <TableView fx:id="usersTable" prefHeight="400">
                            <columns>
                                <TableColumn fx:id="idCol" prefWidth="60" text="ID" />
                                <TableColumn fx:id="fullNameCol" prefWidth="250" text="Nom complet" />
                                <TableColumn fx:id="emailCol" prefWidth="250" text="Email" />
                                <TableColumn fx:id="roleCol" prefWidth="120" text="Rôle" />
                                <TableColumn fx:id="activeCol" prefWidth="100" text="Actif" />
                            </columns>
                        </TableView>
                        <Label fx:id="adminStatusLabel" styleClass="status" wrapText="true" />
                    </VBox>

                    <!-- Charts Section -->
                    <HBox spacing="20">
                        <VBox spacing="15" styleClass="card" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 16px;" styleClass="title" text="Inscriptions (7 jours)" />
                            <BarChart fx:id="usersCreatedChart" legendVisible="false" prefHeight="250">
                                <xAxis><CategoryAxis /></xAxis>
                                <yAxis><NumberAxis /></yAxis>
                            </BarChart>
                        </VBox>
                        <VBox prefWidth="350" spacing="15" styleClass="card">
                            <Label style="-fx-font-size: 16px;" styleClass="title" text="Répartition des rôles" />
                            <PieChart fx:id="rolesPieChart" legendVisible="true" prefHeight="250" />
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </VBox>

    <!-- AJOUT: Overlay Edit Profile (caché par défaut) -->
    <StackPane fx:id="editProfileBackdrop" alignment="CENTER" managed="false" onMouseClicked="#onCloseEditProfileBackdrop" styleClass="overlay-backdrop" visible="false">
        <VBox fx:id="editProfileCard" alignment="TOP_CENTER" maxWidth="500" onMouseClicked="#consumeEvent" spacing="12" styleClass="overlay-card">
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="title" text="✏️ Modifier mon profil" />
                <Pane HBox.hgrow="ALWAYS" />
                <Button onAction="#onCloseEditProfile" styleClass="btn-link" text="✕" />
            </HBox>

            <Separator />

            <VBox alignment="CENTER" spacing="8">
                <ImageView fx:id="profileAvatarView" fitHeight="100" fitWidth="100" preserveRatio="true" styleClass="avatar-large" />
                <Button onAction="#onChangeProfilePhoto" styleClass="btn-secondary" text="📷 Changer la photo" />
                <Label fx:id="profilePhotoHintLabel" styleClass="hint" text="" />
            </VBox>

            <Separator />

            <Label styleClass="subtitle" text="Nom complet" />
            <TextField fx:id="profileFullNameField" promptText="Nom complet" />

            <Label styleClass="subtitle" text="Email" />
            <TextField fx:id="profileEmailField" promptText="Email" />

            <Label styleClass="subtitle" text="Nouveau mot de passe (optionnel)" />
            <PasswordField fx:id="profileNewPasswordField" promptText="Nouveau mot de passe" />

            <Label styleClass="subtitle" text="Confirmer le mot de passe" />
            <PasswordField fx:id="profileConfirmPasswordField" promptText="Confirmer" />

            <HBox spacing="10">
                <Button onAction="#onSaveProfile" styleClass="btn-primary" text="💾 Enregistrer" HBox.hgrow="ALWAYS" />
                <Button onAction="#onCloseEditProfile" styleClass="btn-secondary" text="Annuler" />
            </HBox>

            <Label fx:id="profileStatusLabel" styleClass="status" wrapText="true" />
        </VBox>
    </StackPane>

    <!-- AJOUT: Overlay Admin Edit User (même style que home.fxml) -->
    <StackPane fx:id="adminEditUserBackdrop" alignment="CENTER" managed="false" onMouseClicked="#onAdminEditUserBackdropClick" styleClass="overlay-backdrop" visible="false">
        <VBox fx:id="adminEditUserCard" alignment="TOP_CENTER" maxWidth="500" onMouseClicked="#consumeEvent" spacing="12" styleClass="overlay-card">
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="title" text="✏️ Modifier utilisateur" />
                <Pane HBox.hgrow="ALWAYS" />
                <Button onAction="#onCloseAdminEditUser" styleClass="btn-link" text="✕" />
            </HBox>

            <Separator />

            <Label styleClass="field-label" text="ID" />
            <Label fx:id="adminEditUserIdLabel" text="-" />

            <Label styleClass="field-label" text="Nom complet" />
            <TextField fx:id="adminEditUserFullNameField" promptText="Nom complet" styleClass="enhanced-focus" />

            <Label styleClass="field-label" text="Email" />
            <TextField fx:id="adminEditUserEmailField" promptText="Email" styleClass="enhanced-focus" />

            <Label styleClass="field-label" text="Rôle" />
            <ComboBox fx:id="adminEditUserRoleBox" prefWidth="200" styleClass="enhanced-focus" />

            <CheckBox fx:id="adminEditUserActiveCheck" text="Compte actif" />

            <HBox spacing="10">
                <Button onAction="#onAdminSaveUser" styleClass="btn-primary" text="💾 Enregistrer" HBox.hgrow="ALWAYS" />
                <Button onAction="#onAdminDeleteUser" styleClass="btn-danger" text="🗑️ Supprimer" />
                <Button onAction="#onCloseAdminEditUser" styleClass="btn-secondary" text="Annuler" />
            </HBox>

            <Label fx:id="adminEditUserStatusLabel" styleClass="status" wrapText="true" />
        </VBox>
    </StackPane>

    <!-- AJOUT: Overlay Admin Add User -->
    <StackPane fx:id="adminAddUserBackdrop" alignment="CENTER" managed="false" onMouseClicked="#onAdminAddUserBackdropClick" styleClass="overlay-backdrop" visible="false">
        <VBox fx:id="adminAddUserCard" alignment="TOP_CENTER" maxWidth="500" onMouseClicked="#consumeEvent" spacing="12" styleClass="overlay-card">
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="title" text="➕ Ajouter un utilisateur" />
                <Pane HBox.hgrow="ALWAYS" />
                <Button onAction="#onCloseAdminAddUser" styleClass="btn-link" text="✕" />
            </HBox>

            <Separator />

            <Label styleClass="field-label" text="Nom complet" />
            <TextField fx:id="adminAddUserFullNameField" promptText="Nom complet" styleClass="enhanced-focus" />

            <Label styleClass="field-label" text="Email" />
            <TextField fx:id="adminAddUserEmailField" promptText="Email" styleClass="enhanced-focus" />

            <Label styleClass="field-label" text="Mot de passe" />
            <PasswordField fx:id="adminAddUserPasswordField" promptText="Mot de passe (min 6 caractères)" styleClass="enhanced-focus" />

            <Label styleClass="field-label" text="Rôle" />
            <ComboBox fx:id="adminAddUserRoleBox" prefWidth="200" styleClass="enhanced-focus" />

            <CheckBox fx:id="adminAddUserActiveCheck" selected="true" text="Compte actif" />

            <HBox spacing="10">
                <Button onAction="#onAdminSaveNewUser" styleClass="btn-primary" text="💾 Créer l'utilisateur" HBox.hgrow="ALWAYS" />
                <Button onAction="#onCloseAdminAddUser" styleClass="btn-secondary" text="Annuler" />
            </HBox>

            <Label fx:id="adminAddUserStatusLabel" styleClass="status" wrapText="true" />
        </VBox>
    </StackPane>
</StackPane>
