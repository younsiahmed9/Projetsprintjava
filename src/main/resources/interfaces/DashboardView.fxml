<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DashboardController">
    <VBox fx:id="root" spacing="20" style="-fx-background-color: #f5f7fa; -fx-padding: 20;">

        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Text style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #182d88;" text="Tableau de bord administrateur" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#refreshDashboard" style="-fx-background-color: #182d88; -fx-text-fill: white; -fx-background-radius: 5;" text="Rafraîchir" />
            <Button onAction="#exportStats" style="-fx-background-color: #8dbc71; -fx-text-fill: white; -fx-background-radius: 5;" text="Exporter" />
        </HBox>

        <!-- Cartes de statistiques -->
        <HBox spacing="20">
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                <Text style="-fx-font-size: 14px; -fx-fill: #718096;" text="Services" />
                <Text fx:id="totalServices" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-fill: #182d88;" text="0" />
            </VBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                <Text style="-fx-font-size: 14px; -fx-fill: #718096;" text="Produits" />
                <Text fx:id="totalProduits" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-fill: #182d88;" text="0" />
            </VBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                <Text style="-fx-font-size: 14px; -fx-fill: #718096;" text="Paiements" />
                <Text fx:id="totalPaiements" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-fill: #182d88;" text="0" />
            </VBox>

            <VBox style="-fx-background-color: #182d88; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(24,45,136,0.3), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                <Text style="-fx-font-size: 14px; -fx-fill: white;" text="CA Total" />
                <Text fx:id="chiffreAffaires" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-fill: white;" text="0 TND" />
            </VBox>

            <VBox style="-fx-background-color: #8dbc71; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(141,188,113,0.3), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                <Text style="-fx-font-size: 14px; -fx-fill: white;" text="CA du mois" />
                <Text fx:id="caMois" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-fill: white;" text="0 TND" />
            </VBox>
        </HBox>

        <!-- Graphiques -->
        <HBox spacing="20">
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                <Text style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-fill: #182d88;" text="Services par type" />
                <PieChart fx:id="servicesPieChart" prefHeight="200" />
            </VBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                <Text style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-fill: #182d88;" text="Produits par type" />
                <PieChart fx:id="produitsPieChart" prefHeight="200" />
            </VBox>
        </HBox>

        <!-- Graphique des revenus -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Text style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-fill: #182d88;" text="Revenus par mois" />
            <BarChart fx:id="revenusBarChart" prefHeight="300">
                <xAxis>
                    <CategoryAxis fx:id="moisAxis" side="BOTTOM" />
                </xAxis>
                <yAxis>
                    <NumberAxis fx:id="montantAxis" side="LEFT" label="Montant (TND)" />
                </yAxis>
            </BarChart>
        </VBox>

        <!-- Alertes -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Text style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-fill: #182d88;" text="Alertes" />
            <VBox fx:id="alertesContainer" spacing="5" style="-fx-padding: 10;" />
        </VBox>

        <!-- Tables récentes -->
        <TabPane>
            <Tab text="Services récents">
                <TableView fx:id="servicesTable" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="serviceIdCol" prefWidth="50" text="ID" />
                        <TableColumn fx:id="serviceNomCol" prefWidth="150" text="Nom" />
                        <TableColumn fx:id="serviceTypeCol" prefWidth="100" text="Type" />
                        <TableColumn fx:id="serviceTarifCol" prefWidth="100" text="Tarif" />
                        <TableColumn fx:id="serviceStatutCol" prefWidth="100" text="Statut" />
                    </columns>
                </TableView>
            </Tab>
            <Tab text="Produits récents">
                <TableView fx:id="produitsTable" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="produitIdCol" prefWidth="50" text="ID" />
                        <TableColumn fx:id="produitNomCol" prefWidth="150" text="Nom" />
                        <TableColumn fx:id="produitTypeCol" prefWidth="120" text="Type" />
                        <TableColumn fx:id="produitMontantCol" prefWidth="100" text="Montant" />
                        <TableColumn fx:id="produitStatutCol" prefWidth="100" text="Statut" />
                    </columns>
                </TableView>
            </Tab>
            <Tab text="Paiements récents">
                <TableView fx:id="paiementsTable" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="paiementIdCol" prefWidth="50" text="ID" />
                        <TableColumn fx:id="paiementMontantCol" prefWidth="100" text="Montant" />
                        <TableColumn fx:id="paiementDateCol" prefWidth="100" text="Date" />
                        <TableColumn fx:id="paiementModeCol" prefWidth="120" text="Mode" />
                        <TableColumn fx:id="paiementStatutCol" prefWidth="100" text="Statut" />
                    </columns>
                </TableView>
            </Tab>
        </TabPane>

        <!-- Note explicative -->
        <Text style="-fx-font-size: 11px; -fx-fill: #718096;"
              text="Double-cliquez sur un élément dans les tables pour voir les détails complets" />
    </VBox>
</ScrollPane>