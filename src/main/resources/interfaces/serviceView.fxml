<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<ScrollPane fitToWidth="true" styleClass="main-container" stylesheets="@/styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ServiceController">
    <content>
        <VBox spacing="15">
            <!-- Top Bar avec tous les boutons -->
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="top-bar">
                <padding>
                    <Insets bottom="10" left="15" right="15" top="10" />
                </padding>

                <!-- Recherche -->
                <HBox styleClass="search-box" HBox.hgrow="ALWAYS">
                    <TextField fx:id="searchServiceField" promptText="Rechercher un service..." styleClass="search-field" HBox.hgrow="ALWAYS" prefWidth="200"/>
                </HBox>

                <!-- Filtre Statut -->
                <ComboBox fx:id="filterStatutService" prefWidth="120" promptText="Statut" styleClass="filter-combo" />

                <!-- BOUTONS -->
                <Button fx:id="addServiceButton" onAction="#ajouterService" styleClass="btn-add" text="+ Service" />
                <Button fx:id="addProductButton" onAction="#ajouterProduit" styleClass="btn-add" text="+ Produit" />
                <Button fx:id="factureButton" onAction="#handleFactures" styleClass="btn-primary" text="📄 Factures" />
                <Button fx:id="dashboardButton" onAction="#openDashboard" styleClass="btn-primary" text="📊 Dashboard" />
                <Button fx:id="promoButton" onAction="#handlePromotion" styleClass="btn-promo" text="🎯 Promos" />
                <!-- Ajoutez ce bouton dans la barre d'outils -->
                <Button fx:id="smsButton" onAction="#handleOuvrirSMS" styleClass="btn-info" text="📱 SMS"/>            </HBox>

            <!-- Stats Cards (simples) -->
            <HBox spacing="20" styleClass="stats-container" alignment="CENTER">
                <padding>
                    <Insets left="15" right="15" top="10" />
                </padding>

                <VBox styleClass="stats-card" prefWidth="150">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Circle fill="#f78f34" radius="8" />
                        <Text styleClass="stats-title" text="Services" />
                    </HBox>
                    <Text fx:id="totalServices" styleClass="stats-number" text="0" />
                </VBox>

                <VBox styleClass="stats-card" prefWidth="150">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Circle fill="#fecf47" radius="8" />
                        <Text styleClass="stats-title" text="Produits" />
                    </HBox>
                    <Text fx:id="totalProduits" styleClass="stats-number" text="0" />
                </VBox>
            </HBox>

            <!-- Statistiques détaillées -->
            <HBox spacing="20" styleClass="charts-container">
                <padding>
                    <Insets left="15" right="15" />
                </padding>

                <!-- Statistiques Services -->
                <VBox styleClass="stats-card-large" HBox.hgrow="ALWAYS" spacing="10">
                    <Label text="📊 Statistiques Services" styleClass="stats-title-large" />
                    <GridPane hgap="10" vgap="5">
                        <Label text="Total services :" styleClass="stat-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="statTotalServices" text="0" styleClass="stat-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Services actifs :" styleClass="stat-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="statServicesActifs" text="0" styleClass="stat-value-success" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Services suspendus :" styleClass="stat-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="statServicesSuspendus" text="0" styleClass="stat-value-warning" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Services expirés :" styleClass="stat-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="statServicesExpires" text="0" styleClass="stat-value-error" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <!-- Statistiques Produits -->
                <VBox styleClass="stats-card-large" HBox.hgrow="ALWAYS" spacing="10">
                    <Label text="📦 Statistiques Produits" styleClass="stats-title-large" />
                    <GridPane hgap="10" vgap="5">
                        <Label text="Total produits :" styleClass="stat-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="statTotalProduits" text="0" styleClass="stat-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Produits disponibles :" styleClass="stat-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="statProduitsDisponibles" text="0" styleClass="stat-value-success" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Produits épuisés :" styleClass="stat-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="statProduitsEpuses" text="0" styleClass="stat-value-warning" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Montant total :" styleClass="stat-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="statMontantTotal" text="0 DT" styleClass="stat-value" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>
            </HBox>

            <!-- Onglets pour Services et Produits -->
            <TabPane VBox.vgrow="ALWAYS">
                <padding>
                    <Insets left="15" right="15" bottom="15" />
                </padding>

                <Tab text="Services" closable="false">
                    <ScrollPane fitToWidth="true" fitToHeight="true">
                        <FlowPane fx:id="servicesFlow" hgap="15" vgap="15" styleClass="flow-pane" />
                    </ScrollPane>
                </Tab>

                <Tab text="Produits" closable="false">
                    <ScrollPane fitToWidth="true" fitToHeight="true">
                        <FlowPane fx:id="produitsFlow" hgap="15" vgap="15" styleClass="flow-pane" />
                    </ScrollPane>
                </Tab>
            </TabPane>
        </VBox>
    </content>
</ScrollPane>