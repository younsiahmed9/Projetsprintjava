<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox spacing="0" stylesheets="@/css/app.css,@/css/theme-orange.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.LoginController">

    <!-- Colonne gauche (formulaire) -->
    <StackPane maxWidth="420" minWidth="420" prefWidth="420" styleClass="left-panel">
        <padding>
            <Insets top="26" right="22" bottom="26" left="22" />
        </padding>

        <VBox spacing="14" styleClass="card" maxWidth="380">

            <HBox alignment="CENTER" spacing="10">
                <ImageView fitHeight="80" fitWidth="140" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/assets/logo.png" />
                    </image>
                </ImageView>
            </HBox>

            <Region prefHeight="8" />

            <Label styleClass="title" text="Login into your account" />

            <VBox spacing="6">
                <Label styleClass="field-label" text="Email address" />
                <TextField fx:id="emailField" promptText="alex@gmail.com" />
            </VBox>

            <VBox spacing="6">
                <Label styleClass="field-label" text="Password" />

                <StackPane>
                    <PasswordField fx:id="passwordField" promptText="Enter your password" />
                    <TextField fx:id="passwordVisibleField" managed="false" promptText="Enter your password" visible="false" />
                </StackPane>

                <CheckBox fx:id="showPasswordCheck" text="Afficher le mot de passe" />
            </VBox>

            <Button maxWidth="1.7976931348623157E308" onAction="#onLogin" styleClass="btn-primary" text="Login now" />

            <Separator />

            <!-- Bouton Face ID en priorité et en couleur principale -->
            <VBox spacing="8">
                <Button fx:id="faceLoginBtn" maxWidth="1.7976931348623157E308" onAction="#onFaceLogin" styleClass="btn-primary" text="👤 Se connecter avec Face ID" />
                <Label fx:id="faceStatusLabel" wrapText="true" style="-fx-font-size: 11px; -fx-text-alignment: center;" />
            </VBox>

            <Separator />

            <HBox spacing="12">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Button fx:id="fingerprintLoginBtn" maxWidth="1.7976931348623157E308" onAction="#onFingerprintLogin" styleClass="btn-secondary" text="🔐 Empreinte" />
                    <Label fx:id="fingerprintStatusLabel" wrapText="true" style="-fx-font-size: 11px; -fx-text-alignment: center;" />
                </VBox>
            </HBox>

            <Separator />

            <Button maxWidth="1.7976931348623157E308" onAction="#onGoRegister" styleClass="btn-secondary" text="Signup now" />

            <Label fx:id="statusLabel" styleClass="status" wrapText="true" />

        </VBox>
    </StackPane>

    <!-- Colonne droite (illustration) -->
    <StackPane styleClass="right-panel" HBox.hgrow="ALWAYS">
        <ImageView preserveRatio="true" smooth="true" fitWidth="760">
            <image>
                <Image url="@/assets/illustration.png" />
            </image>
        </ImageView>
    </StackPane>

</HBox>
