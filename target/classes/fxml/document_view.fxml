<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1.0"
            fx:controller="Controllers.DocumentViewController"
            stylesheets="@../css/styles.css"
            styleClass="main-container">

    <top>
        <VBox spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Gestion des Documents" styleClass="header-title-blue"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnAddDocument" text="+" styleClass="btn-add-circle"/>
            </HBox>
            <Label text="Organisez et gerez vos documents en toute facilite"
                   style="-fx-font-size: 13; -fx-text-fill: #666;"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="25" VBox.vgrow="ALWAYS">
            <!-- Carte Dossiers (≈30%) -->
            <VBox spacing="12" styleClass="card"
                  prefWidth="330" minWidth="300" maxWidth="380"
                  maxHeight="Infinity">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📁 Dossiers" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnManageFolders" text="⚙" styleClass="btn-icon-small"/>
                </HBox>

                <Separator />

                <Button fx:id="btnAllDocuments" text="📋 Tous les documents" styleClass="folder-button"/>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="containerFolders" spacing="5" style="-fx-padding: 5;"/>
                </ScrollPane>

                <Button fx:id="btnAddFolder" text="+ Ajouter un dossier" maxWidth="Infinity" styleClass="btn-secondary"/>
            </VBox>

            <!-- Carte Documents (≈70%) -->
            <VBox spacing="12" styleClass="card"
                  HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="tfSearch"
                               promptText="🔍 Rechercher un document..."
                               styleClass="search-field"
                               HBox.hgrow="ALWAYS"
                               style="-fx-padding: 10 15; -fx-font-size: 12; -fx-border-radius: 8;"/>

                    <ComboBox fx:id="cbCategory"
                              promptText="📁 Categorie"
                              styleClass="filter-combo"
                              prefWidth="180"/>

                    <Button fx:id="btnManageCategories" text="🏷" styleClass="btn-icon-small"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblDocCount" text="0 documents" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblFilterInfo" text="" style="-fx-font-size: 11; -fx-text-fill: #1d4ed8; -fx-font-weight: bold;"/>
                    <Button fx:id="btnRefresh" text="⟳" styleClass="btn-icon-small"/>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="containerDocuments" spacing="10" style="-fx-padding: 5;"/>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #f7f9fc; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0; -fx-padding: 10 30;">
            <Label fx:id="lblStatus" text="Pret" style="-fx-font-size: 11; -fx-text-fill: #666;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="v2.0" style="-fx-font-size: 10; -fx-text-fill: #999;"/>
        </HBox>
    </bottom>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
</BorderPane>
