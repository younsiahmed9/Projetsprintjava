<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="card" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml" fx:controller="Controllers.SimulateurEpargneController">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="📈 Simulateur d'Épargne &amp; Investissement" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #182d88;"/>

    <Label fx:id="capaciteLabel" text="Votre budget global restant ce mois-ci : 0.00 DT" style="-fx-font-size: 16; -fx-text-fill: #000; -fx-font-weight: bold;"/>

    <GridPane hgap="15" vgap="15">
        <Label text="Quel est votre objectif ? :" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-size: 14;"/>
        <TextField fx:id="objectifField" promptText="Ex: Acheter une voiture, Voyage..." GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300" style="-fx-font-size: 14; -fx-padding: 8;"/>

        <Label text="Montant cible (DT) :" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-size: 14;"/>
        <TextField fx:id="montantCibleField" promptText="Ex: 15000" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-size: 14; -fx-padding: 8;"/>

        <Label text="Délai souhaité (Mois) :" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-size: 14;"/>
        <TextField fx:id="delaiMoisField" promptText="Ex: 12" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-font-size: 14; -fx-padding: 8;"/>
    </GridPane>

    <HBox spacing="15" style="-fx-padding: 15 0 0 0;">
        <Button text="🧮 Calculer" styleClass="btn-primary" style="-fx-background-color: #182d88; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 10 20; -fx-background-radius: 5;" onAction="#onCalculer"/>
        <Button text="⬅ Retour" styleClass="btn-secondary" style="-fx-background-color: #ccc; -fx-text-fill: black; -fx-font-size: 14; -fx-padding: 10 20; -fx-background-radius: 5;" onAction="#onRetour"/>
    </HBox>

    <VBox style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
        <Label fx:id="resultatLabel" wrapText="true" text="Entrez vos informations pour lancer la simulation." style="-fx-font-size: 15; -fx-line-spacing: 5;"/>
    </VBox>
</VBox>
