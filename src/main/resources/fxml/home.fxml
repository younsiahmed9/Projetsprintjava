<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="600.0" prefWidth="1000.0" styleClass="root" stylesheets="@/css/app.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.HomeController">
<HBox>
        <!-- Sidebar -->
        <VBox prefWidth="250" spacing="10" styleClass="sidebar" style="-fx-padding: 20 15;">
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 0 0 30 0;">
                <ImageView fitHeight="80" fitWidth="160" preserveRatio="true">
                    <image>
                        <Image url="@/assets/logo.png" />
                    </image>
                </ImageView>
            </VBox>
            
            <Button alignment="BASELINE_LEFT" styleClass="side-nav-button, side-nav-button-active" text="📊 Overview" maxWidth="Infinity" />
            <Button alignment="BASELINE_LEFT" styleClass="side-nav-button" text="📝 Transactions" maxWidth="Infinity" />
            <Button alignment="BASELINE_LEFT" styleClass="side-nav-button" text="💳 Accounts" maxWidth="Infinity" />
            <Button alignment="BASELINE_LEFT" styleClass="side-nav-button" text="📄 Invoices" maxWidth="Infinity" />
            <Button alignment="BASELINE_LEFT" styleClass="side-nav-button" text="🎯 Goals" maxWidth="Infinity" />
            <Pane VBox.vgrow="ALWAYS" />
            <Button alignment="BASELINE_LEFT" styleClass="side-nav-button" text="⚙️ Settings" maxWidth="Infinity" />
        </VBox>

        <!-- Main Content -->
        <VBox spacing="16" style="-fx-padding: 20;" HBox.hgrow="ALWAYS">
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label fx:id="welcomeLabel" styleClass="title" text="Bienvenue" />
                <Pane HBox.hgrow="ALWAYS" />
                <Button onAction="#onOpenChat" styleClass="btn-secondary" text="💬 Chat" />
                <Button onAction="#onToggleTheme" styleClass="btn-secondary" text="🎨 Thème" />
                <Button onAction="#onLogout" styleClass="btn-primary" text="🚪 Déconnexion" />
            </HBox>

        <ScrollPane fitToWidth="true" styleClass="modern-scroll-pane" VBox.vgrow="ALWAYS">
            <VBox spacing="20">
                <!-- Section Transactions centralisée -->
                <VBox fx:id="transactionsSection" managed="false" spacing="20" visible="false">
                    <Label style="-fx-font-size: 28px;" styleClass="title" text="Mes Transactions" />
                    
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Button styleClass="btn-primary" text="+ Nouvelle Transaction" />
                        <Button styleClass="btn-secondary" text="🔄 Rafraîchir" />
                    </HBox>

                    <!-- Tableau stylisé -->
                    <VBox spacing="0" styleClass="card">
                        <HBox spacing="20" style="-fx-padding: 15; -fx-background-color: #f9fafb; -fx-background-radius: 12 12 0 0; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
                            <Label style="-fx-font-weight: bold; -fx-min-width: 150;" text="Article" />
                            <Label style="-fx-font-weight: bold; -fx-min-width: 120;" text="Boutique" />
                            <Label style="-fx-font-weight: bold; -fx-min-width: 120;" text="Date" />
                            <Label style="-fx-font-weight: bold; -fx-min-width: 140;" text="Méthode" />
                            <Label style="-fx-font-weight: bold; -fx-min-width: 100; -fx-alignment: CENTER-RIGHT;" text="Montant" />
                        </HBox>
                        <VBox fx:id="transactionsList" spacing="0" />
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
        </VBox>
    </HBox>
</StackPane>
