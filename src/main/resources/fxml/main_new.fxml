<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1.0"
            fx:controller="Controllers.MainController"
            stylesheets="@../css/styles.css"
            styleClass="main-container">

    <!-- LEFT: Sidebar avec navigation -->
    <left>
        <VBox styleClass="sidebar" spacing="10">
            <!-- Logo + Titre -->
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 0 0 30 0;">
                <ImageView fitHeight="48" fitWidth="48" preserveRatio="true" smooth="true" styleClass="app-logo">
                    <Image url="@../assets/logo.png"/>
                </ImageView>
                <Label text="FinTrack" styleClass="app-title" style="-fx-font-size: 24;"/>
            </VBox>

            <!-- Boutons de navigation -->
            <Button fx:id="btnDashboard" text="📊 Dashboard" styleClass="menu-button"
                    onAction="#loadDashboardView" maxWidth="Infinity"/>

            <Button fx:id="btnDocuments" text="📄 Documents" styleClass="menu-button"
                    onAction="#loadDocumentView" maxWidth="Infinity"/>


            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- User info en bas -->
            <VBox alignment="CENTER" spacing="5" style="-fx-padding: 20 0 0 0; -fx-border-color: #EEE; -fx-border-width: 1 0 0 0;">
                <Label text="👤 Administrateur" style="-fx-font-size: 12; -fx-text-fill: #666; -fx-font-weight: bold;"/>
                <Label text="Version 1.0" style="-fx-font-size: 10; -fx-text-fill: #999;"/>
            </VBox>
        </VBox>
    </left>

    <!-- CENTER: Contenu dynamique -->
    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>
