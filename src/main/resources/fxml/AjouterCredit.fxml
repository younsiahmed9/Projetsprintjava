<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" styleClass="popup-container"
      stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.AjouterCreditController"
      prefWidth="500" maxWidth="500">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <VBox alignment="CENTER" spacing="8">
        <Label text="Nouvelle Demande" styleClass="header-title-blue" style="-fx-font-size: 24;"/>
        <Label text="Analyse de solvabilité et calcul de mensualité en temps réel."
               wrapText="true" style="-fx-text-fill: #999; -fx-text-alignment: center; -fx-font-size: 13;"/>
    </VBox>

    <Separator style="-fx-opacity: 0.3;"/>

    <VBox spacing="15">
        <VBox spacing="5">
            <Label text="MONTANT DU CRÉDIT (DT)" styleClass="card-type-header" style="-fx-font-size: 10;"/>
            <TextField fx:id="txtMontant" promptText="Ex: 15000" styleClass="modern-input"/>
        </VBox>

        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="TAUX (%)" styleClass="card-type-header" style="-fx-font-size: 10;"/>
                <TextField fx:id="txtTaux" promptText="5.5" styleClass="modern-input"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="DURÉE (MOIS)" styleClass="card-type-header" style="-fx-font-size: 10;"/>
                <TextField fx:id="txtDuree" promptText="24" styleClass="modern-input"/>
            </VBox>
        </HBox>

        <VBox spacing="5">
            <Label text="NUMÉRO DE TÉLÉPHONE (OPTIONNEL)" styleClass="card-type-header" style="-fx-font-size: 10;"/>
            <TextField fx:id="txtTelephone" promptText="Ex: +21655123456" styleClass="modern-input"/>
            <Label text="Format : + (code pays) (numéro)" style="-fx-font-size: 9; -fx-text-fill: #aaa;"/>
        </VBox>

        <VBox spacing="5" style="-fx-background-color: #f8f9fa; -fx-padding: 12; -fx-background-radius: 10; -fx-border-color: #eee;">
            <Label text="MENSUALITÉ ESTIMÉE" styleClass="card-type-header" style="-fx-text-fill: #666; -fx-font-size: 9;"/>
            <Label fx:id="lblMensualite" text="0.00 DT" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #3e893e;"/>
        </VBox>

        <VBox spacing="8" style="-fx-padding: 5 0 0 0;">
            <Label text="INDICE DE CONFIANCE (SOLVABILITÉ)" styleClass="card-type-header" style="-fx-font-size: 10;"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <ProgressBar fx:id="progressScore" progress="0.0" prefWidth="280.0" styleClass="score-bar" />
                <Label fx:id="lblScore" text="Analyse..." style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
            </HBox>
        </VBox>
    </VBox>

    <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
        <Button text="Annuler" onAction="#handleAnnuler" styleClass="btn-cancel" prefWidth="120" prefHeight="40"/>
        <Button text="Confirmer" onAction="#handleConfirmer" styleClass="btn-details-orange" prefWidth="200" prefHeight="40"/>
    </HBox>

</VBox>