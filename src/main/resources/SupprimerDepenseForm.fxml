<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.scene.control.*?>
        <?import javafx.scene.layout.*?>
        <?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controllers.SupprimerDepenseController"
      spacing="15">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label text="Supprimer une dépense"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <Label text="Rechercher par ID:"
               style="-fx-font-size: 14px;"/>
        <TextField fx:id="txtSearchId"
                   promptText="Entrez l'ID de la dépense"
                   prefWidth="200"/>
        <Button text="Rechercher"
                onAction="#onRechercher"/>
    </HBox>

    <Separator/>

    <VBox fx:id="depenseDetailsBox" spacing="10">
        <Label text="Détails de la dépense:"
               style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <TextArea fx:id="txtDetails"
                  editable="false"
                  prefRowCount="6"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Supprimer"
                style="-fx-font-size: 14px; -fx-padding: 10px 30px; -fx-text-fill: white; -fx-background-color: #d32f2f;"
                onAction="#onSupprimer"/>

        <Button text="Annuler"
                style="-fx-font-size: 14px; -fx-padding: 10px 30px;"
                onAction="#onAnnuler"/>
    </HBox>

</VBox>