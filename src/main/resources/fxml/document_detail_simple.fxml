<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1.0"
            fx:controller="Controllers.DocumentDetailController"
            stylesheets="@../css/styles.css"
            style="-fx-background-color: #f5f7fa;">

    <top>
        <VBox styleClass="detail-header">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label fx:id="lblTitle" text="Détail du Document" style="-fx-font-size: 28; -fx-font-weight: 900; -fx-text-fill: #1e293b;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnTranslate" text="🌐 Traduire" styleClass="btn-secondary, btn-detail-action" />
                <Button fx:id="btnShare" text="↗ Partager" styleClass="btn-secondary, btn-detail-action" />
                <Button fx:id="btnEdit" text="✎ Modifier" styleClass="btn-primary, btn-detail-action" />
                <Button fx:id="btnClose" text="✕" styleClass="btn-icon-small"/>
            </HBox>
            <Label fx:id="lblPath" text="Chemin: " style="-fx-font-size: 12; -fx-text-fill: #64748b; -fx-padding: 12 0 0 0;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <VBox spacing="24" style="-fx-padding: 30;">
                <!-- Informations du document -->
                <VBox spacing="15" styleClass="detail-card-premium">
                    <Label text="📋 INFORMATIONS DU DOCUMENT" styleClass="detail-section-title"/>
                    <Separator style="-fx-opacity: 0.3;"/>

                    <VBox spacing="12">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Description:" styleClass="detail-label"/>
                            <Label fx:id="lblDescription" text="-" wrapText="true" styleClass="detail-value" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Catégorie:" styleClass="detail-label"/>
                            <Label fx:id="lblCategory" text="-" styleClass="detail-value"/>
                        </HBox>
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Dossier:" styleClass="detail-label"/>
                            <Label fx:id="lblFolder" text="-" styleClass="detail-value"/>
                        </HBox>
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Date de création:" styleClass="detail-label"/>
                            <Label fx:id="lblCreatedDate" text="-" styleClass="detail-value"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Relevé Financier -->
                <!-- (Déjà mis à jour avec le style premium dans l'étape précédente, on peut encore l'affiner si besoin, mais restons cohérent) -->
                <VBox spacing="15" styleClass="detail-card-premium" style="-fx-border-color: #3b82f6; -fx-border-width: 2;">
                    <Label text="💰 RELEVÉ FINANCIER" styleClass="detail-section-title" style="-fx-text-fill: #2563eb;"/>
                    <Separator style="-fx-opacity: 0.3;"/>
                    
                    <HBox spacing="50" alignment="CENTER_LEFT">
                        <VBox spacing="8">
                            <Label text="Montant Total" styleClass="detail-label" style="-fx-min-width: 0;"/>
                            <Label fx:id="lblBudget" text="0.000 TND" style="-fx-font-size: 26; -fx-font-weight: 900; -fx-text-fill: #2563eb;"/>
                        </VBox>
                        <VBox spacing="8">
                            <Label text="Statut du Budget" styleClass="detail-label" style="-fx-min-width: 0;"/>
                            <Label fx:id="lblBudgetStatus" text="N/A" style="-fx-padding: 8 16; -fx-background-radius: 25; -fx-font-weight: 800; -fx-font-size: 12;"/>
                        </VBox>
                        <VBox spacing="8">
                            <Label text="Devise Locale" styleClass="detail-label" style="-fx-min-width: 0;"/>
                            <Label text="TND (Dinar Tunisien)" style="-fx-font-size: 15; -fx-font-weight: 700; -fx-text-fill: #1e293b;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Fichier associé -->
                <VBox spacing="15" styleClass="detail-card-premium">
                    <Label text="📁 FICHIER ASSOCIÉ" styleClass="detail-section-title"/>
                    <Separator style="-fx-opacity: 0.3;"/>

                    <VBox spacing="10">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Type de document:" styleClass="detail-label"/>
                            <Label fx:id="lblFileType" text="-" styleClass="detail-value"/>
                        </HBox>
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Taille du fichier:" styleClass="detail-label"/>
                            <Label fx:id="lblFileSize" text="-" styleClass="detail-value"/>
                        </HBox>
                        <HBox spacing="15" alignment="TOP_LEFT">
                            <Label text="Emplacement:" styleClass="detail-label"/>
                            <Label fx:id="lblFilePath" text="-" wrapText="true" styleClass="detail-value" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <HBox spacing="12" style="-fx-padding: 15 0 0 0;">
                        <Button fx:id="btnOpenFile" text="📂 Ouvrir le fichier" styleClass="btn-secondary, btn-detail-action" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button fx:id="btnOpenFolder" text="📂 Voir le dossier" styleClass="btn-secondary, btn-detail-action" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #f7f9fc; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0; -fx-padding: 15 30;">
            <Label fx:id="lblStatus" text="Chargé" style="-fx-font-size: 11; -fx-text-fill: #666;"/>
        </HBox>
    </bottom>

</BorderPane>

