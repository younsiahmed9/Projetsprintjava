<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<DialogPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="interfaces.AjoutServiceController">
    <header>
        <Text style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-fill: #182d88;" text="Ajouter un nouveau service" />
    </header>

    <content>
        <GridPane hgap="10" vgap="10">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <!-- Ligne 0 : Nom -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #182d88;" text="Nom :" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="nomField" promptText="Nom du service" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Label fx:id="nomError" style="-fx-font-size: 11px; -fx-pref-width: 150;" text="" GridPane.columnIndex="2" GridPane.rowIndex="0" />

            <!-- Ligne 1 : Type -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #182d88;" text="Type :" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <ComboBox fx:id="typeCombo" prefWidth="200" promptText="Sélectionner le type" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label fx:id="typeError" style="-fx-font-size: 11px; -fx-pref-width: 150;" text="" GridPane.columnIndex="2" GridPane.rowIndex="1" />

            <!-- Ligne 2 : Tarif -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #182d88;" text="Tarif (TND) :" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="tarifField" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label fx:id="tarifError" style="-fx-font-size: 11px; -fx-pref-width: 150;" text="" GridPane.columnIndex="2" GridPane.rowIndex="2" />

            <!-- Ligne 3 : Fréquence -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #182d88;" text="Fréquence :" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <ComboBox fx:id="frequenceCombo" prefWidth="200" promptText="Fréquence (pour abonnement)" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Label fx:id="frequenceError" style="-fx-font-size: 11px; -fx-pref-width: 150;" text="" GridPane.columnIndex="2" GridPane.rowIndex="3" />

            <!-- Ligne 4 : Date début -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #182d88;" text="Date début :" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <DatePicker fx:id="dateDebut" promptText="JJ/MM/AAAA" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            <Label fx:id="dateError" style="-fx-font-size: 11px; -fx-pref-width: 150;" text="" GridPane.columnIndex="2" GridPane.rowIndex="4" />

            <!-- Ligne 5 : Date fin -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #182d88;" text="Date fin :" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <DatePicker fx:id="dateFin" promptText="JJ/MM/AAAA (optionnel)" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            <Label fx:id="dateFinError" style="-fx-font-size: 11px; -fx-pref-width: 150;" text="" GridPane.columnIndex="2" GridPane.rowIndex="5" />

            <!-- Ligne 6 : Statut -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #182d88;" text="Statut :" GridPane.columnIndex="0" GridPane.rowIndex="6" />
            <ComboBox fx:id="statutCombo" prefWidth="200" promptText="Statut" GridPane.columnIndex="1" GridPane.rowIndex="6" />
            <Label fx:id="statutError" style="-fx-font-size: 11px; -fx-pref-width: 150;" text="" GridPane.columnIndex="2" GridPane.rowIndex="6" />

            <!-- Ligne 7 : Produit lié (optionnel) -->
            <Label style="-fx-font-weight: bold; -fx-text-fill: #182d88;" text="Produit lié :" GridPane.columnIndex="0" GridPane.rowIndex="7" />
            <ComboBox fx:id="produitCombo" prefWidth="200" promptText="Produit (optionnel)" GridPane.columnIndex="1" GridPane.rowIndex="7" />
        </GridPane>
    </content>

    <ButtonType fx:constant="OK" />
    <ButtonType fx:constant="CANCEL" />
</DialogPane>