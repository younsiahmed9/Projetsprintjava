<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1.0"
            fx:controller="Controllers.DocumentDetailController"
            stylesheets="@../css/styles.css"
            style="-fx-background-color: #f5f7fa;">

    <top>
        <VBox style="-fx-background-color: #ffffff; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0; -fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label fx:id="lblTitle" text="Détail du Document" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnEdit" text="✎ Modifier" styleClass="btn-primary" />
                <Button fx:id="btnClose" text="✕" styleClass="btn-icon-small"/>
            </HBox>
            <Label fx:id="lblPath" text="Chemin: " style="-fx-font-size: 11; -fx-text-fill: #6b7280; -fx-padding: 10 0 0 0;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-padding: 0; -fx-border-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 20;">
                <!-- Informations du document -->
                <VBox spacing="10" styleClass="card" style="-fx-padding: 20;">
                    <Label text="📋 INFORMATIONS DU DOCUMENT" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                    <Separator/>

                    <HBox spacing="20">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <HBox spacing="10">
                                <Label text="Description:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                <Label fx:id="lblDescription" text="-" wrapText="true" HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <HBox spacing="10">
                                <Label text="Catégorie:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                <Label fx:id="lblCategory" text="-" HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <HBox spacing="10">
                                <Label text="Dossier:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                <Label fx:id="lblFolder" text="-" HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <HBox spacing="10">
                                <Label text="Date de création:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                <Label fx:id="lblCreatedDate" text="-" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Relevé Financier -->
                <VBox spacing="10" styleClass="card" style="-fx-padding: 20; -fx-background-color: #f0f9ff; -fx-border-color: #0284c7; -fx-border-width: 1; -fx-border-radius: 8;">
                    <Label text="💰 RELEVÉ FINANCIER" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                    <Separator/>

                    <HBox spacing="30" alignment="CENTER_LEFT">
                        <VBox spacing="5">
                            <Label text="Montant" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
                            <Label fx:id="lblBudget" text="0.00 €" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0284c7;"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Statut" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
                            <Label fx:id="lblBudgetStatus" text="N/A" style="-fx-padding: 5 10; -fx-background-color: #f3f4f6; -fx-border-radius: 5;"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Devise" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
                            <Label text="EUR" style="-fx-font-size: 14;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Fichier associé -->
                <VBox spacing="10" styleClass="card" style="-fx-padding: 20;">
                    <Label text="📁 FICHIER ASSOCIÉ" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                    <Separator/>

                    <HBox spacing="10">
                        <Label text="Type:" style="-fx-font-weight: bold; -fx-min-width: 100;"/>
                        <Label fx:id="lblFileType" text="-"/>
                    </HBox>
                    <HBox spacing="10">
                        <Label text="Taille:" style="-fx-font-weight: bold; -fx-min-width: 100;"/>
                        <Label fx:id="lblFileSize" text="-"/>
                    </HBox>
                    <HBox spacing="10">
                        <Label text="Chemin:" style="-fx-font-weight: bold; -fx-min-width: 100;"/>
                        <Label fx:id="lblFilePath" text="-" wrapText="true" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="btnOpenFile" text="🔓 Ouvrir" styleClass="btn-secondary" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnOpenFolder" text="📁 Dossier" styleClass="btn-secondary" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #f7f9fc; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0; -fx-padding: 15 30;">
            <Label fx:id="lblStatus" text="Chargé" style="-fx-font-size: 11; -fx-text-fill: #666;"/>
        </HBox>
    </bottom>

</BorderPane>

