<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1.0"
      fx:controller="Controllers.DocumentViewController"
      stylesheets="@../css/styles.css"
      spacing="25"
      style="-fx-background-color: #F4F7FB;">

    <!-- Header Section -->
    <VBox spacing="5">
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label text="Gestion des Documents" styleClass="header-title-blue"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAddDocument" text="+" styleClass="btn-add-circle"
                    style="-fx-font-size: 24; -fx-font-weight: bold;"/>
        </HBox>
        <Label text="Organisez et gérez vos documents, dossiers et catégories en un seul endroit"
               style="-fx-text-fill: #666; -fx-font-size: 14;"/>
    </VBox>

    <!-- Quick Actions Cards -->
    <HBox spacing="20">
        <!-- Card Dossiers -->
        <VBox styleClass="account-card" spacing="12" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <Label text="📁" style="-fx-font-size: 32;"/>
            <Label text="Dossiers" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #182d88;"/>
            <Label fx:id="lblFolderCount" text="0 dossiers" style="-fx-text-fill: #666; -fx-font-size: 12;"/>
            <Button fx:id="btnManageFolders" text="Gérer" styleClass="btn-primary" maxWidth="Infinity"/>
        </VBox>

        <!-- Card Catégories -->
        <VBox styleClass="account-card" spacing="12" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <Label text="🏷️" style="-fx-font-size: 32;"/>
            <Label text="Catégories" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #182d88;"/>
            <Label fx:id="lblCategoryCount" text="0 catégories" style="-fx-text-fill: #666; -fx-font-size: 12;"/>
            <Button fx:id="btnManageCategories" text="Gérer" styleClass="btn-primary" maxWidth="Infinity"/>
        </VBox>

        <!-- Card Documents -->
        <VBox styleClass="account-card" spacing="12" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <Label text="📄" style="-fx-font-size: 32;"/>
            <Label text="Documents" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #182d88;"/>
            <Label fx:id="lblDocCount" text="0 documents" style="-fx-text-fill: #666; -fx-font-size: 12;"/>
            <Label fx:id="lblFilterInfo" text="Tous les documents" style="-fx-text-fill: #FFC107; -fx-font-size: 11; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <!-- Search and Filters Section -->
    <VBox styleClass="card" spacing="20">
        <Label text="Recherche et Filtres" styleClass="section-title"/>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <TextField fx:id="tfSearch"
                       promptText="🔍 Rechercher un document par titre..."
                       styleClass="search-field"
                       HBox.hgrow="ALWAYS"
                       style="-fx-padding: 12 20; -fx-font-size: 13; -fx-border-radius: 10; -fx-background-radius: 10;"/>

            <ComboBox fx:id="cbFolderFilter"
                      promptText="📁 Tous les dossiers"
                      styleClass="filter-combo"
                      prefWidth="200"
                      style="-fx-font-size: 12;"/>

            <ComboBox fx:id="cbCategory"
                      promptText="🏷️ Toutes les catégories"
                      styleClass="filter-combo"
                      prefWidth="200"
                      style="-fx-font-size: 12;"/>

            <Button fx:id="btnRefresh" text="🔄" styleClass="btn-refresh"
                    style="-fx-font-size: 18; -fx-min-width: 45; -fx-max-width: 45; -fx-min-height: 45; -fx-max-height: 45;"/>
        </HBox>

        <!-- Filter Tags -->
        <HBox fx:id="filterTagsContainer" spacing="10" alignment="CENTER_LEFT">
            <Label text="Filtres actifs:" style="-fx-font-size: 11; -fx-text-fill: #666;"/>
        </HBox>
    </VBox>

    <!-- Documents List Section -->
    <VBox styleClass="card" spacing="20" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="Liste des Documents" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAllDocuments" text="📋 Tous" styleClass="filter-link filter-active"/>
            <Button fx:id="btnViewGrid" text="⊞ Grille" styleClass="filter-link"/>
            <Button fx:id="btnViewList" text="☰ Liste" styleClass="filter-link filter-active"/>
        </HBox>

        <!-- Documents ListView with Cards -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" prefHeight="600" minHeight="400"
                   style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <ListView fx:id="listDocuments" prefHeight="600" minHeight="400"
                     style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 5;"/>
        </ScrollPane>

        <!-- Pagination (if needed) -->
        <HBox alignment="CENTER" spacing="10">
            <Label fx:id="lblPagination" text="Affichage de 1-10 sur 0 documents"
                   style="-fx-font-size: 11; -fx-text-fill: #666;"/>
        </HBox>
    </VBox>

    <!-- Status Bar -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 0;">
        <Label fx:id="lblStatus" text="✓ Prêt" style="-fx-font-size: 11; -fx-text-fill: #22c55e; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Dernière mise à jour: " style="-fx-font-size: 10; -fx-text-fill: #999;"/>
        <Label fx:id="lblLastUpdate" text="--:--" style="-fx-font-size: 10; -fx-text-fill: #666;"/>
    </HBox>

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>
</VBox>

