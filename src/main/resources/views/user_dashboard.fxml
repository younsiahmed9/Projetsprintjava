<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.UserDashboardController"
            style="-fx-background-color: #f0f2f5;">

    <!-- TOP - HEADER -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #2c5aa0, #5dade2); -fx-padding: 20;">
            i already pushed my work to github in this link https://github.com/younsiahmed9/Projetsprintjava.git

            and the branch name is gestion-portefeuille and the push i did before is for the crud and the test unitaire niw i want to puch the work that i added interfaces that's it            <!-- Navigation Bar -->
            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 0 0 15 0;">
                <Label text="FinTrack" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Dashboard" onAction="#handleRefresh" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 5; -fx-font-weight: bold;"/>
                <Button text="Transactions" onAction="#handleGoToTransactions" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 5;"/>
            </HBox>
            <!-- User Info Row -->
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label fx:id="welcomeLabel" style="-fx-font-size: 14; -fx-text-fill: white;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Rafraichir" onAction="#handleRefresh" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5;"/>
                <Button text="Deconnexion" onAction="#handleDeconnexion" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5;"/>
            </HBox>
            <Label fx:id="statsLabel" style="-fx-font-size: 12; -fx-text-fill: #e0e0e0; -fx-padding: 10 0 0 0;"/>
        </VBox>
    </top>

    <!-- CENTER - CONTENT -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">

            <!-- LEFT - MES PORTEFEUILLES -->
            <VBox spacing="15" style="-fx-min-width: 450; -fx-max-width: 500;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Mes Portefeuilles" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a3a52;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nouveau" onAction="#handleAjouterPortefeuille" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold;"/>
                </HBox>

                <ScrollPane style="-fx-background-color: transparent; -fx-background: transparent;" fitToWidth="true" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="portefeuillesContainer" hgap="15" vgap="15" style="-fx-padding: 10;"/>
                </ScrollPane>
            </VBox>

            <!-- RIGHT - CARTES DU PORTEFEUILLE -->
            <VBox spacing="15" HBox.hgrow="ALWAYS">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="cartesTitle" text="Cartes du portefeuille" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a3a52;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nouvelle Carte" onAction="#handleAjouterCarte" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold;"/>
                </HBox>

                <ScrollPane style="-fx-background-color: transparent; -fx-background: transparent;" fitToWidth="true" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="cartesContainer" hgap="15" vgap="15" style="-fx-padding: 10;"/>
                </ScrollPane>
            </VBox>

        </HBox>
    </center>

    <!-- BOTTOM - MESSAGE -->
    <bottom>
        <HBox style="-fx-background-color: white; -fx-padding: 15 20; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
            <Label fx:id="messageLabel" style="-fx-font-size: 13;"/>
        </HBox>
    </bottom>

</BorderPane>
